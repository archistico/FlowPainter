<Window
    x:Class="FlowPainter.App.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="FlowPainter"
    Width="1660"
    Height="940"
    MinWidth="1280"
    MinHeight="760"
    WindowStartupLocation="CenterScreen">
    <Grid RowDefinitions="Auto,*,Auto" Background="#17191D">
        <Border Padding="22,16" Background="#202329">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="3">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="White" Text="FlowPainter" />
                    <TextBlock Foreground="#AEB4BF" Text="M13.4.1 · dirty state and data-loss protection" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button x:Name="OpenProjectButton" Padding="16,9" Click="OpenProjectClick" Content="Open project" />
                    <Button x:Name="SaveProjectButton" Padding="16,9" Click="SaveProjectClick" Content="Save project" IsEnabled="False" />
                    <Button x:Name="OpenButton" Padding="16,9" Click="OpenImageClick" Content="Open image" />
                    <Button x:Name="RenderButton" Padding="16,9" Click="RenderPreviewClick" Content="Render preview" IsEnabled="False" />
                    <Button x:Name="CancelButton" Padding="16,9" Click="CancelClick" Content="Cancel" IsEnabled="False" />
                    <Button x:Name="SaveButton" Padding="16,9" Click="SavePngClick" Content="Save preview" IsEnabled="False" />
                    <Button x:Name="ExportFinalButton" Padding="16,9" Click="ExportFinalClick" Content="Export final" IsEnabled="False" />
                    <Button x:Name="ExportSvgButton" Padding="16,9" Click="ExportSvgClick" Content="Export SVG" IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20" ColumnDefinitions="370,*,*" ColumnSpacing="18">
            <Border Background="#202329" CornerRadius="10" Padding="14">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Margin="2,0,2,12" FontSize="17" FontWeight="SemiBold" Foreground="White" Text="Generative and detail parameters" />
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SettingsPanel" Margin="0,0,18,0" Spacing="10">
                            <TextBlock Foreground="#AEB4BF" Text="Project name" />
                            <TextBox x:Name="ProjectNameTextBox" />

                            <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Foreground="White" Text="Generative engine" />
                            <ComboBox x:Name="GenerativeModeComboBox" HorizontalAlignment="Stretch" SelectionChanged="GenerativeModeChanged" />

                            <TextBlock Foreground="#AEB4BF" Text="Recent projects" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <ComboBox x:Name="RecentProjectComboBox" HorizontalAlignment="Stretch" />
                                <Button Grid.Column="1" Click="OpenRecentProjectClick" Content="Open" />
                            </Grid>

                            <TextBlock Foreground="#AEB4BF" Text="Preview quality" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <ComboBox x:Name="PreviewQualityComboBox" HorizontalAlignment="Stretch" />
                                <Button Grid.Column="1" Click="RebuildPreviewClick" Content="Rebuild" />
                            </Grid>

                            <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Foreground="White" Text="Final output" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Max dimension (px)" />
                                <TextBox x:Name="FinalMaximumDimensionTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <TextBlock Foreground="#AEB4BF" Text="Format" />
                            <ComboBox x:Name="FinalFormatComboBox" HorizontalAlignment="Stretch" SelectionChanged="FinalOutputSettingsChanged" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="JPEG quality" />
                                <TextBox x:Name="JpegQualityTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Button Click="UpdateFinalEstimateClick" Content="Update output estimate" />
                            <TextBlock x:Name="FinalOutputInfoText" TextWrapping="Wrap" Foreground="#AEB4BF" Text="Open an image to estimate final output." />
                            <TextBlock x:Name="FinalMemoryInfoText" TextWrapping="Wrap" Foreground="#7F8794" Text="Memory estimate unavailable." />

                            <TextBlock Foreground="#AEB4BF" Text="Built-in preset" />
                            <ComboBox x:Name="PresetComboBox" HorizontalAlignment="Stretch" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Click="LoadPresetClick" Content="Load preset" />
                                <Button Grid.Column="1" Click="SavePresetClick" Content="Save preset" />
                            </Grid>
                            <TextBlock Foreground="#AEB4BF" Text="Recent presets" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <ComboBox x:Name="RecentPresetComboBox" HorizontalAlignment="Stretch" />
                                <Button Grid.Column="1" Click="LoadRecentPresetClick" Content="Load" />
                            </Grid>

                            <TextBlock Margin="0,8,0,0" Foreground="#AEB4BF" Text="Preset name" />
                            <TextBox x:Name="PresetNameTextBox" />

                            <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="White" Text="Geometric primitives" />
                            <TextBlock Foreground="#AEB4BF" Text="Allowed shapes" />
                            <ComboBox x:Name="PrimitiveKindsComboBox" HorizontalAlignment="Stretch" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Primitives" />
                                <TextBox x:Name="PrimitiveCountTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Candidates / step" />
                                <TextBox x:Name="PrimitiveCandidatesTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Mutations" />
                                <TextBox x:Name="PrimitiveMutationsTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Minimum size (%)" />
                                <TextBox x:Name="PrimitiveMinimumSizeTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Maximum size (%)" />
                                <TextBox x:Name="PrimitiveMaximumSizeTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Opacity (%)" />
                                <TextBox x:Name="PrimitiveOpacityTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Detail size influence (%)" />
                                <TextBox x:Name="PrimitiveDetailSizeTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Detail placement bias" />
                                <TextBox x:Name="PrimitivePlacementBiasTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Detail error weight" />
                                <TextBox x:Name="PrimitiveErrorWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Detail search influence" />
                                <TextBox x:Name="PrimitiveSearchInfluenceTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>

                            <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="White" Text="Hybrid composition" />
                            <TextBlock Foreground="#AEB4BF" Text="Primitive flow influence" />
                            <ComboBox x:Name="HybridInfluenceKindComboBox" HorizontalAlignment="Stretch" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Primitive budget (%)" />
                                <TextBox x:Name="HybridPrimitiveBudgetTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Flow budget (%)" />
                                <TextBox x:Name="HybridFlowBudgetTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Refinement budget (%)" />
                                <TextBox x:Name="HybridRefinementBudgetTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Flow influence (%)" />
                                <TextBox x:Name="HybridInfluenceStrengthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Influence radius" />
                                <TextBox x:Name="HybridInfluenceRadiusTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Max nearby primitives" />
                                <TextBox x:Name="HybridMaximumInfluencesTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Refinement detail bias" />
                                <TextBox x:Name="HybridRefinementDetailBiasTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Refinement length (%)" />
                                <TextBox x:Name="HybridRefinementLengthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Refinement width (%)" />
                                <TextBox x:Name="HybridRefinementWidthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>

                            <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Foreground="White" Text="Flow field" />
                            <ComboBox x:Name="FlowFieldComboBox" HorizontalAlignment="Stretch" />

                            <TextBlock Foreground="#AEB4BF" Text="Background" />
                            <ComboBox x:Name="BackgroundComboBox" HorizontalAlignment="Stretch" />

                            <TextBlock Foreground="#AEB4BF" Text="Seed" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox x:Name="SeedTextBox" />
                                <Button Grid.Column="1" Click="NewSeedClick" Content="New" />
                            </Grid>

                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Strokes" />
                                <TextBox x:Name="StrokeCountTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Segments" />
                                <TextBox x:Name="SegmentCountTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Field scale" />
                                <TextBox x:Name="FieldScaleTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Octaves" />
                                <TextBox x:Name="OctavesTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Persistence" />
                                <TextBox x:Name="PersistenceTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Lacunarity" />
                                <TextBox x:Name="LacunarityTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Field rotation (°)" />
                                <TextBox x:Name="AngleOffsetTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Uniform density" />
                                <TextBox x:Name="DensityTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Length scale" />
                                <TextBox x:Name="LengthScaleTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Max curve (°)" />
                                <TextBox x:Name="MaximumCurveTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Min width (px)" />
                                <TextBox x:Name="MinimumWidthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Max width (px)" />
                                <TextBox x:Name="MaximumWidthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Opacity (%)" />
                                <TextBox x:Name="OpacityTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>

                            <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="White" Text="Brush rendering" />
                            <TextBlock Foreground="#AEB4BF" Text="Brush type" />
                            <ComboBox x:Name="BrushKindComboBox" HorizontalAlignment="Stretch" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Hardness (%)" />
                                <TextBox x:Name="BrushHardnessTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Size jitter (%)" />
                                <TextBox x:Name="BrushSizeJitterTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Opacity jitter (%)" />
                                <TextBox x:Name="BrushOpacityJitterTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Bristle count" />
                                <TextBox x:Name="BrushBristleCountTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Bristle spread (%)" />
                                <TextBox x:Name="BrushBristleSpreadTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <TextBlock TextWrapping="Wrap" Foreground="#7F8794" Text="Hardness affects SoftRound and Bristle. Bristle count/spread affect Bristle. Jitter is deterministic for preview and final export." />

                            <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="White" Text="Automatic detail analysis" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Base detail (%)" />
                                <TextBox x:Name="BaseDetailTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Edge weight" />
                                <TextBox x:Name="EdgeWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Contrast weight" />
                                <TextBox x:Name="ContrastWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Smoothing radius" />
                                <TextBox x:Name="SmoothingRadiusTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Button Click="ReanalyzeDetailClick" Content="Reanalyze detail + subjects + boundaries" />

                            <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="White" Text="Semantic importance" />
                            <CheckBox x:Name="EnableSemanticAnalysisCheckBox"
                                      Content="Enable generic subject analysis"
                                      IsChecked="True" />
                            <TextBlock Foreground="#AEB4BF" Text="Overlay map" />
                            <ComboBox x:Name="SemanticOverlayModeComboBox"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="SemanticOverlayModeChanged" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Overall influence (%)" />
                                <TextBox x:Name="SemanticInfluenceTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Saliency weight" />
                                <TextBox x:Name="SemanticSaliencyWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Subject weight" />
                                <TextBox x:Name="SemanticSubjectWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Silhouette weight" />
                                <TextBox x:Name="SemanticSilhouetteWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Focal weight" />
                                <TextBox x:Name="SemanticFocalWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Subject threshold (%)" />
                                <TextBox x:Name="SemanticThresholdTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Minimum area (%)" />
                                <TextBox x:Name="SemanticMinimumAreaTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Maximum subjects" />
                                <TextBox x:Name="SemanticMaximumSubjectsTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Center bias" />
                                <TextBox x:Name="SemanticCenterBiasTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Semantic smoothing" />
                                <TextBox x:Name="SemanticSmoothingRadiusTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Silhouette radius" />
                                <TextBox x:Name="SemanticBoundaryRadiusTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <TextBlock x:Name="SemanticRegionCountText"
                                       Foreground="#AEB4BF"
                                       Text="No semantic subjects analyzed" />
                            <ListBox x:Name="SemanticRegionListBox"
                                     Height="105"
                                     SelectionChanged="SemanticRegionSelectionChanged" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Click="SetSemanticPrimarySubjectClick" Content="Set primary subject" />
                                <Button Grid.Column="1" Click="SetSemanticSubjectClick" Content="Mark as subject" />
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Click="SetSemanticBackgroundClick" Content="Mark as background" />
                                <Button Grid.Column="1" Click="IgnoreSemanticDetectionClick" Content="Ignore detection" />
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Click="PromoteSemanticFocusClick" Content="Promote to focus" />
                                <Button Grid.Column="1" Click="PromoteSemanticCriticalClick" Content="Critical detail" />
                            </Grid>
                            <TextBlock Margin="0,6,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="Semantic corrections" />
                            <TextBlock x:Name="SemanticCorrectionCountText"
                                       Foreground="#AEB4BF"
                                       Text="0 semantic corrections" />
                            <ListBox x:Name="SemanticCorrectionListBox"
                                     Height="90"
                                     SelectionChanged="SemanticCorrectionSelectionChanged" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Click="DeleteSelectedSemanticCorrectionClick" Content="Delete selected" />
                                <Button Grid.Column="1" Click="ClearSemanticCorrectionsClick" Content="Clear corrections" />
                            </Grid>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#7F8794"
                                       Text="Click a detected rectangle to select it, then correct its role. Manual corrections are saved in the project and override automatic semantic maps using the same soft transition as detail regions." />

                            <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="White" Text="Scene boundaries" />
                            <CheckBox x:Name="EnableBoundaryAnalysisCheckBox"
                                      Content="Analyze important edges and background"
                                      IsChecked="True" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Luminance weight" />
                                <TextBox x:Name="BoundaryLuminanceWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Colour weight" />
                                <TextBox x:Name="BoundaryColorWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Multiscale weight" />
                                <TextBox x:Name="BoundaryMultiscaleWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Continuity weight" />
                                <TextBox x:Name="BoundaryContinuityWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Silhouette weight" />
                                <TextBox x:Name="BoundarySemanticWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Texture suppression (%)" />
                                <TextBox x:Name="BoundaryTextureSuppressionTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Edge threshold (%)" />
                                <TextBox x:Name="BoundaryEdgeThresholdTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Important threshold (%)" />
                                <TextBox x:Name="BoundaryImportantThresholdTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Coarse radius" />
                                <TextBox x:Name="BoundaryCoarseRadiusTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Boundary smoothing" />
                                <TextBox x:Name="BoundarySmoothingRadiusTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Silhouette protection" />
                                <TextBox x:Name="BoundaryProtectionRadiusTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#7F8794"
                                       Text="M11 classifies important contours, internal structure, texture, background confidence and tangent direction." />

                            <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="White" Text="Boundary-aware painting" />
                            <CheckBox x:Name="EnableBoundaryPaintingCheckBox"
                                      Content="Guide and stop strokes at important edges" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Tangent alignment (%)" />
                                <TextBox x:Name="BoundaryTangentAlignmentTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Alignment radius" />
                                <TextBox x:Name="BoundaryAlignmentRadiusTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Crossing penalty (%)" />
                                <TextBox x:Name="BoundaryCrossingPenaltyTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Hard edge threshold (%)" />
                                <TextBox x:Name="BoundaryHardThresholdTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Termination strength (%)" />
                                <TextBox x:Name="BoundaryTerminationStrengthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Internal edge influence (%)" />
                                <TextBox x:Name="BoundaryInternalInfluenceTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Texture influence (%)" />
                                <TextBox x:Name="BoundaryTextureInfluenceTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Contour reinforcement" />
                                <TextBox x:Name="BoundaryContourReinforcementTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Corner preservation (%)" />
                                <TextBox x:Name="BoundaryCornerPreservationTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#7F8794"
                                       Text="Near important contours, strokes progressively follow the tangent. Strong silhouette crossings are deflected or stopped while low-value texture remains comparatively free." />

                            <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="White" Text="Background suppression" />
                            <CheckBox x:Name="EnableBackgroundSuppressionCheckBox"
                                      Content="Simplify low-importance background" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Overall strength (%)" />
                                <TextBox x:Name="BackgroundSuppressionStrengthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Detail floor (%)" />
                                <TextBox x:Name="BackgroundDetailFloorTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Uncertainty protection (%)" />
                                <TextBox x:Name="BackgroundUncertaintyProtectionTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Silhouette protection (%)" />
                                <TextBox x:Name="BackgroundSilhouetteProtectionTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Transition softness (%)" />
                                <TextBox x:Name="BackgroundTransitionSoftnessTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Placement floor (%)" />
                                <TextBox x:Name="BackgroundPlacementWeightTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Stroke length (%)" />
                                <TextBox x:Name="BackgroundSuppressionLengthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Stroke width (%)" />
                                <TextBox x:Name="BackgroundSuppressionWidthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Segments retained (%)" />
                                <TextBox x:Name="BackgroundSegmentMultiplierTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Curve freedom (%)" />
                                <TextBox x:Name="BackgroundCurveFreedomTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Colour simplification (%)" />
                                <TextBox x:Name="BackgroundColorSimplificationTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#7F8794"
                                       Text="High-confidence background receives fewer, broader and freer strokes. Subjects, uncertain areas, manual focus regions and protected silhouettes retain detail through soft transitions." />

                            <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="White" Text="Detail influence" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Placement bias" />
                                <TextBox x:Name="PlacementBiasTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Detailed length (%)" />
                                <TextBox x:Name="DetailedLengthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Background length (%)" />
                                <TextBox x:Name="BackgroundLengthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Detailed width (%)" />
                                <TextBox x:Name="DetailedWidthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Background width (%)" />
                                <TextBox x:Name="BackgroundWidthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Region transition (%)" />
                                <TextBox x:Name="RegionTransitionWidthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#7F8794"
                                       Text="Manual regions keep full influence in their core and blend gradually across the border. The percentage is measured against the shorter analysis dimension." />

                            <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="White" Text="Manual detail regions" />
                            <TextBlock TextWrapping="Wrap" Foreground="#7F8794" Text="Click a region to select it; drag to add a rectangular focus or background region. Press Delete to remove the selected manual region or semantic correction." />
                            <ComboBox x:Name="DetailIntentComboBox" HorizontalAlignment="Stretch" />
                            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Region strength (%)" />
                                <TextBox x:Name="RegionStrengthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                            </Grid>
                            <CheckBox x:Name="ShowDetailOverlayCheckBox" Click="DetailOverlayVisibilityClick" Content="Show analysis overlay" IsChecked="True" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Click="RemoveLastRegionClick" Content="Remove last" />
                                <Button Grid.Column="1" Click="ClearRegionsClick" Content="Clear regions" />
                            </Grid>
                            <TextBlock x:Name="RegionCountText" Foreground="#AEB4BF" Text="0 manual regions" />
                            <ListBox x:Name="RegionListBox" Height="105" SelectionChanged="RegionSelectionChanged" />
                            <TextBlock Foreground="#AEB4BF" Text="Selected region label" />
                            <TextBox x:Name="RegionLabelTextBox" />
                            <Grid ColumnDefinitions="*,70,*,70" ColumnSpacing="6">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Left %" />
                                <TextBox x:Name="RegionLeftTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="#AEB4BF" Text="Top %" />
                                <TextBox x:Name="RegionTopTextBox" Grid.Column="3" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Grid ColumnDefinitions="*,70,*,70" ColumnSpacing="6">
                                <TextBlock VerticalAlignment="Center" Foreground="#AEB4BF" Text="Width %" />
                                <TextBox x:Name="RegionWidthTextBox" Grid.Column="1" HorizontalContentAlignment="Right" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="#AEB4BF" Text="Height %" />
                                <TextBox x:Name="RegionHeightTextBox" Grid.Column="3" HorizontalContentAlignment="Right" />
                            </Grid>
                            <Button Click="ApplyRegionChangesClick" Content="Apply selected region" />
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                <Button Click="MoveRegionEarlierClick" Content="Earlier" />
                                <Button Grid.Column="1" Click="MoveRegionLaterClick" Content="Later" />
                                <Button Grid.Column="2" Click="DeleteSelectedRegionClick" Content="Delete" />
                            </Grid>

                            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#7F8794" Text="Blue areas receive broader, longer and fewer strokes. Red areas receive shorter, thinner and more numerous strokes." />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#202329" CornerRadius="10" Padding="14">
                <Grid RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto" Margin="2,0,2,12">
                        <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="White" Text="Source / detail map" />
                        <TextBlock x:Name="SourceInfoText" Grid.Column="1" Foreground="#AEB4BF" Text="No image" />
                    </Grid>
                    <Border Grid.Row="1" Background="#111318" CornerRadius="7" ClipToBounds="True">
                        <Grid x:Name="SourceViewportHost"
                              Background="Transparent"
                              PointerPressed="ViewportPointerPressed"
                              PointerMoved="ViewportPointerMoved"
                              PointerReleased="ViewportPointerReleased"
                              PointerWheelChanged="ViewportPointerWheelChanged"
                              SizeChanged="ViewportHostSizeChanged"
                              ToolTip.Tip="Mouse wheel: zoom · Middle button: pan · View synchronized with rendered preview">
                            <Grid x:Name="SourceViewportContent" IsHitTestVisible="False" RenderTransformOrigin="0%,0%">
                                <Image x:Name="SourceImageView" Stretch="Uniform" />
                                <Canvas x:Name="SelectionCanvas"
                                        Background="Transparent"
                                        IsEnabled="False"
                                        SizeChanged="SourceCanvasSizeChanged" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#202329" CornerRadius="10" Padding="14">
                <Grid RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto" Margin="2,0,2,12">
                        <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="White" Text="Rendered preview" />
                        <TextBlock x:Name="ResultInfoText" Grid.Column="1" Foreground="#AEB4BF" Text="Not rendered" />
                    </Grid>
                    <Border Grid.Row="1" Background="#111318" CornerRadius="7" ClipToBounds="True">
                        <Grid x:Name="ResultViewportHost"
                              Background="Transparent"
                              PointerPressed="ViewportPointerPressed"
                              PointerMoved="ViewportPointerMoved"
                              PointerReleased="ViewportPointerReleased"
                              PointerWheelChanged="ViewportPointerWheelChanged"
                              SizeChanged="ViewportHostSizeChanged"
                              ToolTip.Tip="Mouse wheel: zoom · Middle button: pan · View synchronized with source">
                            <Grid x:Name="ResultViewportContent" IsHitTestVisible="False" RenderTransformOrigin="0%,0%">
                                <Image x:Name="ResultImageView" Stretch="Uniform" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="20,12" Background="#202329">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <ProgressBar x:Name="OperationProgressBar" Width="190" Minimum="0" Maximum="100" Value="0" />
                <TextBlock x:Name="StatusText" Grid.Column="1" VerticalAlignment="Center" Foreground="#DCE4F2" Text="Open a local PNG, JPEG, WebP or BMP image." />
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="#8FD19E" Text="Max 10,000 × 10,000 RGBA" />
            </Grid>
        </Border>
    </Grid>
</Window>
